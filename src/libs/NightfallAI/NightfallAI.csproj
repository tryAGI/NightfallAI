<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <NoWarn>$(NoWarn);CS3002;CS3003;CS1591</NoWarn>
  </PropertyGroup>

  <PropertyGroup Label="Nuget">
    <Description>C# SDK for the Nightfall AI API -- data security with PII, PHI, PCI, and secret detection.</Description>
    <PackageId>NightfallAI</PackageId>
    <PackageTags>api;client;sdk;dotnet;openapi;nightfall;data-security;pii-detection;dlp;ai;autosdk</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.AI" Version="10.5.1" />
  </ItemGroup>

</Project>
